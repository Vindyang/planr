generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============================================================
// ENUMS
// ============================================================

enum UserRole {
  STUDENT
  COORDINATOR
  ADMIN
  SUPER_ADMIN
}

enum CourseStatus {
  COMPLETED
  IN_PROGRESS
  PLANNED
}

enum PrerequisiteType {
  HARD
  SOFT
  COREQUISITE
}

enum PlanStatus {
  PLANNED
  ENROLLED
  DROPPED
}

// Announcement system enums
enum AnnouncementScope {
  PLATFORM      // All users across all universities
  UNIVERSITY    // All users in a specific university (requires universityId)
  DEPARTMENT    // All users in a specific department (requires departmentId)
}

enum AnnouncementPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

// Audit logging enums
enum AuditAction {
  CREATE
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  PERMISSION_CHANGE
}

enum AuditEntityType {
  USER
  COURSE
  DEPARTMENT
  UNIVERSITY
  ANNOUNCEMENT
  PREREQUISITE
}

// ============================================================
// CORE MULTI-TENANT ENTITIES
// ============================================================

model university {
  id          String   @id @default(uuid())
  code        String   @unique // SMU, NUS, NTU, SUTD, SUSS
  name        String   // "Singapore Management University"
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  departments              department[]
  courses                  course[]
  students                 student[]
  professors               professor[]
  assignedAdmins           user[]                  @relation("UniversityAdmins")
  graduationRequirements   graduationRequirement[]
  announcements            announcement[]

  @@map("universities")
}

model department {
  id             String   @id @default(uuid())
  universityId   String   @map("university_id")
  code           String   // "IS", "CS", "BUSINESS", "ACCOUNTING"
  name           String   // "Information Systems", "Computer Science"
  description    String?  @db.Text
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  university     university @relation(fields: [universityId], references: [id], onDelete: Cascade)
  courses        course[]
  students       student[]    @relation("StudentMajor")
  secondMajors   student[]    @relation("StudentSecondMajor")
  minors         student[]    @relation("StudentMinor")
  professors     professor[]
  coordinators   user[]
  announcements  announcement[]

  @@unique([universityId, code])
  @@index([universityId, isActive])
  @@map("departments")
}

// ============================================================
// USER & AUTHENTICATION
// ============================================================

model user {
  id                    String      @id @default(uuid())
  email                 String      @unique
  name                  String
  emailVerified         Boolean     @default(false) @map("email_verified")
  image                 String?
  role                  UserRole    @default(STUDENT)

  // Multi-tenant assignments (for ADMIN and COORDINATOR roles)
  assignedUniversityId  String?     @map("assigned_university_id")
  assignedDepartmentId  String?     @map("assigned_department_id")

  createdAt             DateTime    @default(now()) @map("created_at")
  updatedAt             DateTime    @updatedAt @map("updated_at")

  assignedUniversity    university? @relation("UniversityAdmins", fields: [assignedUniversityId], references: [id])
  assignedDepartment    department? @relation(fields: [assignedDepartmentId], references: [id])
  student               student?
  sessions              session[]
  accounts              account[]
  createdAnnouncements  announcement[]
  readAnnouncements     announcementRead[]
  auditLogs             auditLog[]

  @@index([assignedUniversityId])
  @@index([assignedUniversityId, assignedDepartmentId])
  @@index([role])
  @@map("users")
}

// ============================================================
// STUDENT PROFILE
// ============================================================

model student {
  id                     String     @id @default(uuid())
  userId                 String     @unique @map("user_id")
  studentId              String?    @map("student_id")

  universityId           String     @map("university_id")
  majorId                String     @map("major_id")
  secondMajorId          String?    @map("second_major_id")
  minorId                String?    @map("minor_id")

  year                   Int
  enrollmentYear         Int        @map("enrollment_year")
  expectedGraduationYear Int        @map("expected_graduation_year")
  gpa                    Float      @default(0)

  user                user              @relation(fields: [userId], references: [id], onDelete: Cascade)
  university          university        @relation(fields: [universityId], references: [id])
  major               department        @relation("StudentMajor", fields: [majorId], references: [id])
  secondMajor         department?       @relation("StudentSecondMajor", fields: [secondMajorId], references: [id])
  minor               department?       @relation("StudentMinor", fields: [minorId], references: [id])

  completedCourses    completedCourse[]
  semesterPlans       semesterPlan[]
  courseReviews       courseReview[]
  professorReviews    professorReview[]

  @@index([universityId])
  @@index([majorId])
  @@map("students")
}

// ============================================================
// COURSE CATALOG
// ============================================================

model course {
  id             String     @id @default(uuid())
  code           String
  universityId   String     @map("university_id")
  departmentId   String?    @map("department_id") // Nullable for general education courses
  title          String
  description    String     @db.Text
  units          Int
  termsOffered   String[]   @map("terms_offered")
  tags           String[]   // For non-department tags like "Core", "Elective", "Year 1", etc.
  isActive       Boolean    @default(true) @map("is_active")
  createdAt      DateTime   @default(now()) @map("created_at")
  updatedAt      DateTime   @updatedAt @map("updated_at")

  university          university           @relation(fields: [universityId], references: [id])
  department          department?          @relation(fields: [departmentId], references: [id])
  prerequisites       prerequisite[]       @relation("CoursePrerequisites")
  prerequisiteFor     prerequisite[]       @relation("PrerequisiteCourses")
  completedCourses    completedCourse[]
  plannedCourses      plannedCourse[]
  courseInstructors   courseInstructor[]
  courseReviews       courseReview[]
  professorReviews    professorReview[]

  @@unique([code, universityId])
  @@index([universityId, isActive])
  @@index([departmentId])
  @@map("courses")
}

model prerequisite {
  id                   String           @id @default(uuid())
  courseId             String           @map("course_id")
  prerequisiteCourseId String           @map("prerequisite_course_id")
  type                 PrerequisiteType
  notes                String?

  course             course @relation("CoursePrerequisites", fields: [courseId], references: [id], onDelete: Cascade)
  prerequisiteCourse course @relation("PrerequisiteCourses", fields: [prerequisiteCourseId], references: [id], onDelete: Cascade)

  @@index([courseId])
  @@index([prerequisiteCourseId])
  @@map("prerequisites")
}

// ============================================================
// STUDENT PROGRESS
// ============================================================

model completedCourse {
  id        String       @id @default(uuid())
  studentId String       @map("student_id")
  courseId  String       @map("course_id")
  grade     String
  term      String
  status    CourseStatus @default(COMPLETED)
  createdAt DateTime     @default(now()) @map("created_at")

  student student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  course  course  @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@index([courseId])
  @@map("completed_courses")
}

model semesterPlan {
  id        String   @id @default(uuid())
  studentId String   @map("student_id")
  term      String
  year      Int
  isActive  Boolean  @default(false) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  student        student         @relation(fields: [studentId], references: [id], onDelete: Cascade)
  plannedCourses plannedCourse[]

  @@index([studentId])
  @@index([studentId, year, term])
  @@map("semester_plans")
}

model plannedCourse {
  id             String     @id @default(uuid())
  semesterPlanId String     @map("semester_plan_id")
  courseId       String     @map("course_id")
  status         PlanStatus @default(PLANNED)
  addedAt        DateTime   @default(now()) @map("added_at")

  semesterPlan semesterPlan @relation(fields: [semesterPlanId], references: [id], onDelete: Cascade)
  course       course       @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@index([semesterPlanId])
  @@index([courseId])
  @@map("planned_courses")
}

// ============================================================
// GRADUATION REQUIREMENTS
// ============================================================

model graduationRequirement {
  id               String     @id @default(uuid())
  universityId     String     @map("university_id")
  major            String
  requirementType  String     @map("requirement_type")
  requirementValue Json       @map("requirement_value")

  university university @relation(fields: [universityId], references: [id], onDelete: Cascade)

  @@index([universityId, major])
  @@map("graduation_requirements")
}

// ============================================================
// PROFESSORS & INSTRUCTORS
// ============================================================

model professor {
  id             String     @id @default(uuid())
  name           String
  universityId   String     @map("university_id")
  departmentId   String     @map("department_id")
  createdAt      DateTime   @default(now()) @map("created_at")
  updatedAt      DateTime   @updatedAt @map("updated_at")

  university         university         @relation(fields: [universityId], references: [id])
  department         department         @relation(fields: [departmentId], references: [id])
  courseInstructors  courseInstructor[]
  reviews            professorReview[]

  @@unique([name, universityId, departmentId])
  @@index([universityId])
  @@index([departmentId])
  @@map("professors")
}

model courseInstructor {
  id          String  @id @default(uuid())
  courseId    String  @map("course_id")
  professorId String  @map("professor_id")
  term        String?

  course    course    @relation(fields: [courseId], references: [id], onDelete: Cascade)
  professor professor @relation(fields: [professorId], references: [id], onDelete: Cascade)

  @@unique([courseId, professorId, term])
  @@map("course_instructors")
}

// ============================================================
// REVIEWS
// ============================================================

model courseReview {
  id               String   @id @default(uuid())
  studentId        String   @map("student_id")
  courseId         String   @map("course_id")
  rating           Int
  difficultyRating Int      @map("difficulty_rating")
  workloadRating   Int      @map("workload_rating")
  content          String   @db.Text
  term             String
  isAnonymous      Boolean  @default(true) @map("is_anonymous")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  student student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  course  course  @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([studentId, courseId])
  @@index([courseId])
  @@map("course_reviews")
}

model professorReview {
  id               String   @id @default(uuid())
  studentId        String   @map("student_id")
  professorId      String   @map("professor_id")
  courseId         String?  @map("course_id")
  rating           Int
  difficultyRating Int      @map("difficulty_rating")
  workloadRating   Int      @map("workload_rating")
  content          String   @db.Text
  term             String?
  isAnonymous      Boolean  @default(true) @map("is_anonymous")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  student   student    @relation(fields: [studentId], references: [id], onDelete: Cascade)
  professor professor  @relation(fields: [professorId], references: [id], onDelete: Cascade)
  course    course?    @relation(fields: [courseId], references: [id], onDelete: SetNull)

  @@unique([studentId, professorId])
  @@index([professorId])
  @@index([courseId])
  @@map("professor_reviews")
}

// ============================================================
// AUTHENTICATION & SESSIONS
// ============================================================

model session {
  id        String   @id
  expiresAt DateTime @map("expires_at")
  token     String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  ipAddress String?  @map("ip_address")
  userAgent String?  @map("user_agent")
  userId    String   @map("user_id")
  user      user     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@index([userId])
  @@map("sessions")
}

model account {
  id                    String    @id
  accountId             String    @map("account_id")
  providerId            String    @map("provider_id")
  userId                String    @map("user_id")
  user                  user      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?   @map("access_token")
  refreshToken          String?   @map("refresh_token")
  idToken               String?   @map("id_token")
  accessTokenExpiresAt  DateTime? @map("access_token_expires_at")
  refreshTokenExpiresAt DateTime? @map("refresh_token_expires_at")
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  @@index([userId])
  @@map("accounts")
}

model verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime @map("expires_at")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@index([identifier])
  @@map("verifications")
}

// ============================================================
// ANNOUNCEMENT SYSTEM (Multi-Tenant)
// ============================================================

model announcement {
  id             String              @id @default(uuid())
  title          String
  content        String              @db.Text
  scope          AnnouncementScope
  priority       AnnouncementPriority @default(NORMAL)

  // Multi-tenant scoping - supports platform-wide, university-wide, or department-specific
  universityId   String?             @map("university_id")
  departmentId   String?             @map("department_id")

  // Metadata
  createdById    String              @map("created_by_id")
  isActive       Boolean             @default(true) @map("is_active")
  publishedAt    DateTime?           @map("published_at")
  expiresAt      DateTime?           @map("expires_at")
  createdAt      DateTime            @default(now()) @map("created_at")
  updatedAt      DateTime            @updatedAt @map("updated_at")

  // Relations
  university     university?         @relation(fields: [universityId], references: [id])
  department     department?         @relation(fields: [departmentId], references: [id])
  createdBy      user                @relation(fields: [createdById], references: [id])
  readReceipts   announcementRead[]

  @@index([scope, isActive, publishedAt])
  @@index([universityId, isActive])
  @@index([departmentId, isActive])
  @@map("announcements")
}

model announcementRead {
  id              String       @id @default(uuid())
  announcementId  String       @map("announcement_id")
  userId          String       @map("user_id")
  readAt          DateTime     @default(now()) @map("read_at")

  announcement    announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)
  user            user         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([announcementId, userId])
  @@index([userId])
  @@map("announcement_reads")
}

// ============================================================
// AUDIT LOGGING (Multi-Tenant)
// ============================================================

model auditLog {
  id           String           @id @default(uuid())
  action       AuditAction
  entityType   AuditEntityType  @map("entity_type")
  entityId     String?          @map("entity_id")
  userId       String           @map("user_id")
  changes      Json?            // { before: {...}, after: {...} }
  metadata     Json?            // IP address, user agent, etc.
  createdAt    DateTime         @default(now()) @map("created_at")

  user         user             @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([action, createdAt])
  @@index([entityType, entityId])
  @@map("audit_logs")
}
