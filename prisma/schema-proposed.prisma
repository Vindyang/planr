// ============================================================
// PROPOSED SCHEMA - Modular & Scalable Multi-Tenant Design
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============================================================
// CORE ENTITIES - Universities & Departments
// ============================================================

model university {
  id          String   @id @default(uuid())
  code        String   @unique // SMU, NUS, NTU, etc.
  name        String   // "Singapore Management University"
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  departments        department[]
  courses            course[]
  students           student[]
  professors         professor[]
  assignedAdmins     user[]           @relation("UniversityAdmins")
  assignedCoordinators user[]         @relation("DepartmentCoordinators")

  @@map("universities")
}

model department {
  id             String   @id @default(uuid())
  universityId   String   @map("university_id")
  code           String   // "IS", "CS", "BUSINESS"
  name           String   // "Information Systems", "Computer Science"
  description    String?  @db.Text
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  university     university @relation(fields: [universityId], references: [id], onDelete: Cascade)
  courses        course[]
  students       student[]  @relation("StudentMajor")
  secondMajors   student[]  @relation("StudentSecondMajor")
  minors         student[]  @relation("StudentMinor")
  professors     professor[]
  coordinators   user[]

  @@unique([universityId, code])
  @@index([universityId, isActive])
  @@map("departments")
}

// ============================================================
// USER & AUTHENTICATION
// ============================================================

enum UserRole {
  STUDENT
  COORDINATOR
  ADMIN
  SUPER_ADMIN
}

model user {
  id                    String      @id @default(uuid())
  email                 String      @unique
  name                  String
  emailVerified         Boolean     @default(false) @map("email_verified")
  image                 String?
  role                  UserRole    @default(STUDENT)

  // Multi-tenant assignments (for ADMIN and COORDINATOR roles)
  assignedUniversityId  String?     @map("assigned_university_id")
  assignedDepartmentId  String?     @map("assigned_department_id")

  createdAt             DateTime    @default(now()) @map("created_at")
  updatedAt             DateTime    @updatedAt @map("updated_at")

  assignedUniversity    university? @relation("UniversityAdmins", fields: [assignedUniversityId], references: [id])
  assignedDepartment    department? @relation(fields: [assignedDepartmentId], references: [id])
  student               student?
  sessions              session[]
  accounts              account[]

  @@index([assignedUniversityId])
  @@index([assignedUniversityId, assignedDepartmentId])
  @@index([role])
  @@map("users")
}

// ============================================================
// STUDENT PROFILE
// ============================================================

model student {
  id                     String     @id @default(uuid())
  userId                 String     @unique @map("user_id")
  studentId              String?    @map("student_id")

  universityId           String     @map("university_id")
  majorId                String     @map("major_id")
  secondMajorId          String?    @map("second_major_id")
  minorId                String?    @map("minor_id")

  year                   Int
  enrollmentYear         Int        @map("enrollment_year")
  expectedGraduationYear Int        @map("expected_graduation_year")
  gpa                    Float      @default(0)

  user                user              @relation(fields: [userId], references: [id], onDelete: Cascade)
  university          university        @relation(fields: [universityId], references: [id])
  major               department        @relation("StudentMajor", fields: [majorId], references: [id])
  secondMajor         department?       @relation("StudentSecondMajor", fields: [secondMajorId], references: [id])
  minor               department?       @relation("StudentMinor", fields: [minorId], references: [id])

  completedCourses    completedCourse[]
  semesterPlans       semesterPlan[]
  courseReviews       courseReview[]
  professorReviews    professorReview[]

  @@index([universityId])
  @@index([majorId])
  @@map("students")
}

// ============================================================
// COURSE CATALOG
// ============================================================

enum CourseStatus {
  COMPLETED
  IN_PROGRESS
  PLANNED
}

enum PrerequisiteType {
  HARD
  SOFT
  COREQUISITE
}

model course {
  id             String     @id @default(uuid())
  code           String
  universityId   String     @map("university_id")
  departmentId   String?    @map("department_id") // Nullable for general education courses
  title          String
  description    String     @db.Text
  units          Int
  termsOffered   String[]   @map("terms_offered")
  tags           String[]   // For non-department tags like "Core", "Elective", etc.
  isActive       Boolean    @default(true) @map("is_active")
  createdAt      DateTime   @default(now()) @map("created_at")
  updatedAt      DateTime   @updatedAt @map("updated_at")

  university          university           @relation(fields: [universityId], references: [id])
  department          department?          @relation(fields: [departmentId], references: [id])
  prerequisites       prerequisite[]       @relation("CoursePrerequisites")
  prerequisiteFor     prerequisite[]       @relation("PrerequisiteCourses")
  completedCourses    completedCourse[]
  plannedCourses      plannedCourse[]
  courseInstructors   courseInstructor[]
  courseReviews       courseReview[]
  professorReviews    professorReview[]

  @@unique([code, universityId])
  @@index([universityId, isActive])
  @@index([departmentId])
  @@map("courses")
}

// ... (rest of models remain similar with updated references)

model professor {
  id             String     @id @default(uuid())
  name           String
  universityId   String     @map("university_id")
  departmentId   String     @map("department_id")
  createdAt      DateTime   @default(now()) @map("created_at")
  updatedAt      DateTime   @updatedAt @map("updated_at")

  university         university         @relation(fields: [universityId], references: [id])
  department         department         @relation(fields: [departmentId], references: [id])
  courseInstructors  courseInstructor[]
  reviews            professorReview[]

  @@unique([name, universityId, departmentId])
  @@index([universityId])
  @@index([departmentId])
  @@map("professors")
}

